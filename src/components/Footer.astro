---
const phone    = "5491100000000"; // reemplazar con número real
const email    = "Hola@tresvecestres.com.ar";
const linkedin = "https://www.linkedin.com/company/tresvecestres";
const instagram= "https://www.instagram.com/tresvecestres";
const whatsapp = `https://wa.me/${phone}`;
---

<footer class="bg-degrade-3 py-10">
    <div class="container max-w-6xl mx-auto px-8 md:px-16">
        <div class="flex flex-col md:flex-row items-center justify-between gap-10">

            <!-- Logo con slogan -->
            <div class="shrink-0">
                <img
                    src="/images/logos/logo-blanco-slogan.svg"
                    alt="Tres Veces Tres — Comunicación con impacto"
                    class="h-16 w-auto"
                />
            </div>

            <!-- Separador vertical (solo desktop) -->
            <div class="hidden md:block self-stretch w-px bg-white/20"></div>

            <!-- Website Carbon badge (CSS) -->
            <a
                href="https://www.websitecarbon.com/website/tresvecestres-com-ar/"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col items-center gap-1 text-white/70 hover:text-white transition-colors duration-300 text-center"
                aria-label="Website Carbon Badge"
            >
                <div class="flex items-stretch rounded overflow-hidden border border-white/30 text-xs font-mono">
                    <span class="px-3 py-1.5 bg-white/10 text-white">0.2g of CO₂/view</span>
                    <span class="px-3 py-1.5 bg-[#4a7c59] text-white font-bold">Website Carbon</span>
                </div>
                <span class="text-[11px] tracking-wide">Cleaner than 96% of pages tested</span>
            </a>

            <!-- Separador vertical (solo desktop) -->
            <div class="hidden md:block self-stretch w-px bg-white/20"></div>

            <!-- Contacto + redes -->
            <div class="flex flex-col items-center gap-4">
                <!-- Email -->
                <a
                    href={`mailto:${email}`}
                    class="group flex items-center gap-2 text-white hover:text-white/70 transition-colors duration-300"
                >
                    <!-- Ícono sobre -->
                    <svg viewBox="0 0 24 24" class="w-5 h-5 fill-white" aria-hidden="true">
                        <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 2-8 5-8-5h16Zm0 12H4V8.88l7.44 4.65a1 1 0 0 0 1.12 0L20 8.88V18Z"/>
                    </svg>
                    <span class="font-bold text-lg">{email}</span>
                </a>

                <!-- Redes sociales -->
                <div class="flex items-center gap-3">

                    <!-- LinkedIn -->
                    <a
                        href={linkedin}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="LinkedIn de Tres Veces Tres"
                        class="group size-10 rounded-full border-2 border-white bg-white flex items-center justify-center transition-colors duration-300 hover:bg-degrade-3"
                    >
                        <svg viewBox="0 0 24 24" class="size-5 fill-degrade-3 transition-colors duration-300 group-hover:fill-white" aria-hidden="true">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/>
                        </svg>
                    </a>

                    <!-- Instagram -->
                    <a
                        href={instagram}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Instagram de Tres Veces Tres"
                        class="group size-10 rounded-full border-2 border-white bg-white flex items-center justify-center transition-colors duration-300 hover:bg-degrade-3"
                    >
                        <svg viewBox="0 0 24 24" class="size-5 fill-degrade-3 transition-colors duration-300 group-hover:fill-white" aria-hidden="true">
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069ZM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0Zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881Z"/>
                        </svg>
                    </a>

                    <!-- WhatsApp -->
                    <a
                        href={whatsapp}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="WhatsApp de Tres Veces Tres"
                        class="group size-10 rounded-full border-2 border-white bg-white flex items-center justify-center transition-colors duration-300 hover:bg-degrade-3"
                    >
                        <svg viewBox="0 0 24 24" class="size-5 fill-degrade-3 transition-colors duration-300 group-hover:fill-white" aria-hidden="true">
                            <path d="M12.001 2C6.478 2 2 6.478 2 12c0 1.85.504 3.58 1.38 5.068L2.05 21.95l5.02-1.31A9.956 9.956 0 0 0 12 22c5.523 0 10-4.477 10-10S17.524 2 12.001 2Zm0 18a7.95 7.95 0 0 1-4.07-1.117l-.29-.174-3.007.784.804-2.93-.19-.302A7.96 7.96 0 0 1 4 12c0-4.411 3.589-8 8.001-8C16.411 4 20 7.589 20 12s-3.589 8-7.999 8Zm4.38-5.837c-.238-.12-1.407-.693-1.625-.772-.218-.079-.377-.119-.536.12-.158.238-.614.772-.752.931-.139.158-.277.178-.515.059-.238-.12-1.005-.37-1.914-1.18-.707-.63-1.185-1.408-1.323-1.646-.139-.238-.015-.367.104-.485.107-.107.238-.278.357-.417.12-.139.159-.238.238-.397.08-.159.04-.298-.02-.417-.059-.12-.535-1.29-.733-1.766-.193-.464-.39-.4-.535-.408l-.456-.008c-.159 0-.417.06-.635.298-.218.238-.833.814-.833 1.984s.853 2.3.971 2.46c.12.158 1.679 2.563 4.068 3.593.568.245 1.012.391 1.357.5.57.181 1.089.155 1.499.094.457-.068 1.407-.575 1.606-1.13.198-.556.198-1.033.139-1.132-.059-.099-.218-.158-.456-.278Z"/>
                        </svg>
                    </a>

                </div>
            </div>

        </div>
    </div>
</footer>
