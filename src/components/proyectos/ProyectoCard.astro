---
interface Props {
  bg?: string;         // ruta a la imagen de fondo (opcional)
  gradientClass?: string; // clases de gradiente tailwind si no hay imagen
  logo: string;        // ruta al logo
  alt: string;         // alt del logo
  logoWidth?: string;  // clase de ancho del logo, ej: "w-52"
  href?: string;       // enlace al que apunta la tarjeta (opcional)
}

const { bg, gradientClass = '', logo, alt, logoWidth = 'w-52', href = '#' } = Astro.props;
---

<a href={href} class:list={['proyecto-card group relative overflow-hidden w-full h-full cursor-pointer', gradientClass]}>
  {bg && (
    <img
      src={bg}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105"
    />
  )}
  <div class="absolute inset-0 bg-linear-to-r from-10% to-80% from-black/60 to-transparent transition-colors duration-500 group-hover:from-black/30"></div>
  <div class="absolute inset-0 flex items-center justify-center">
    <img
      src={logo}
      alt={alt}
      class:list={[logoWidth, 'max-w-[55%] drop-shadow-xl transition-transform duration-500 group-hover:scale-110']}
    />
  </div>
</a>
