---
import Layout from '@/layouts/Layout.astro';
import HeroGradient from '@/components/HeroGradient.astro';
import ContactForm from '@/components/contacto/ContactForm.astro';
import { SITE_KEY } from "astro:env/client";
---

<Layout
    title="Contacto | Tres Veces Tres"
    canonical="https://tresvecestres.com.ar/contacto"
    metaDescription="Contactá a Tres Veces Tres para conversar sobre tu proyecto de comunicación y marketing."
    metaImg=""
>
    <HeroGradient>
        <span class="flex flex-col items-start w-fit mx-auto text-left">
            <span class="italic ml-8 md:ml-16">Contanos</span>
            <span class="italic">sobre tu</span>
            <strong class="font-semibold sm:font-bold ml-16 md:ml-24">proyecto</strong>
        </span>
    </HeroGradient>
    <ContactForm />
</Layout>

<!-- recaptcha v3 -->
<script async src={'https://www.google.com/recaptcha/api.js?render=' + SITE_KEY}></script>