---
---

<section class="relative overflow-hidden">

    <!-- PARTE BLANCA: cita -->
    <div class="relative bg-white z-20">
        <div class="relative max-w-[1200px] 2xl:max-w-[1100px] mx-auto px-8 md:px-16 py-20 md:py-32 flex flex-col justify-center">
            
            <!-- Símbolo decorativo: sobresale hacia abajo y arriba -->
            <!-- Lo posicionamos absoluto a la derecha. Ajustamos su tamaño y traslación por breakpoints -->
            <img
                src="/images/logos/tresvecestres/simbolo-bg.svg"
                alt="símbolo de Tres Veces Tres decorativo"
                aria-hidden="true"
                loading="lazy"
                class="opacity-20 xs:opacity-100 absolute z-0 pointer-events-none select-none right-0 -top-[5%] sm:-top-[8%] md:-top-[12%] lg:-top-[15%] h-[115%] sm:h-[125%] md:h-[130%] w-auto max-w-none object-contain object-right translate-x-[40%] xs:translate-x-[30%] sm:translate-x-[15%] md:translate-x-[5%] lg:translate-x-[2%] xl:-translate-x-[5%]"
                data-aos="fade-left"
                data-aos-duration="1000"
            />
            <img
                src="/images/logos/tresvecestres/simbolo-bg.svg"
                alt="símbolo de Tres Veces Tres decorativo en modo oscuro"
                aria-hidden="true"
                loading="lazy"
                style="filter: brightness(0) invert(1) opacity(0.45);"
                class="opacity-50 xs:opacity-100 absolute z-0 pointer-events-none select-none right-0 -top-[5%] sm:-top-[8%] md:-top-[12%] lg:-top-[15%] h-[115%] sm:h-[125%] md:h-[130%] w-auto max-w-none object-contain object-right translate-x-[40%] xs:translate-x-[30%] sm:translate-x-[15%] md:translate-x-[5%] lg:translate-x-[2%] xl:-translate-x-[5%] hidden dark:block"
                data-aos="fade-left"
                data-aos-duration="1000"
            />

            <!-- Contenedor del texto relativo para que quede por encima del SVG (z-10) -->
            <div
                class="relative z-10 max-w-[85%] sm:max-w-[70%] md:max-w-[70%] lg:max-w-[55%]"
                data-aos="fade-right"
                data-aos-duration="800"
                data-aos-delay="200"
            >
                <!-- Comillas -->
                <svg class="size-12 md:size-16 lg:size-20 mb-4 md:mb-6 text-gray-300 fill-current rotate-180" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <g fill="none">
                        <path fill-opacity="0.16" d="M10.99 9.449c.178 3.09-1.998 7.444-6.88 9.551L3 17.08c1.997-1.123 3.507-2.95 4.306-5.15c-2.886-.234-3.729-2.013-3.729-3.464c0-1.967 1.51-3.512 3.374-3.465c1.775-.047 3.817 1.311 4.039 4.448m10 0c.178 3.09-1.997 7.444-6.88 9.551L13 17.08c1.998-1.123 3.507-2.95 4.306-5.15c-2.886-.234-3.729-2.013-3.729-3.464c0-1.967 1.51-3.512 3.374-3.465c1.775-.047 3.817 1.311 4.039 4.448" />
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-miterlimit="10" stroke-width="1.5" d="M10.99 9.449c.178 3.09-1.998 7.444-6.88 9.551L3 17.08c1.997-1.123 3.507-2.95 4.306-5.15c-2.886-.234-3.729-2.013-3.729-3.464c0-1.967 1.51-3.512 3.374-3.465c1.775-.047 3.817 1.311 4.039 4.448m10 0c.178 3.09-1.997 7.444-6.88 9.551L13 17.08c1.998-1.123 3.507-2.95 4.306-5.15c-2.886-.234-3.729-2.013-3.729-3.464c0-1.967 1.51-3.512 3.374-3.465c1.775-.047 3.817 1.311 4.039 4.448" />
                    </g>
                </svg>

                <blockquote class="text-2xl md:text-3xl lg:text-4xl xl:text-4xl font-light italic text-gray-800 leading-snug lg:leading-tight">
                    Todo lo positivo que hagas te será devuelto, multiplicado por tres&rdquo;.
                </blockquote>
            </div>
        </div>
    </div>

    <!-- PARTE NEGRA: quiénes somos -->
    <div class="relative bg-[#0c0c0c] py-20 sm:py-32 z-10">
        <div class="max-w-5xl mx-auto px-8 md:px-16">
            <div class="flex flex-col md:flex-row items-start md:items-center gap-10 md:gap-16">

                <!-- Logo blanco letras (vertical) -->
                <div
                    class="shrink-0"
                    data-aos="fade-right"
                    data-aos-duration="800"
                >
                    <img
                        src="/images/logos/tresvecestres/logo-blanco-letras.svg"
                        alt="Tres Veces Tres"
                        loading="lazy"
                        class="w-28 md:w-36 lg:w-44"
                    />
                </div>

                <!-- Texto -->
                <p
                    class="text-white text-lg md:text-xl lg:text-2xl max-w-xl leading-relaxed"
                    data-aos="fade-left"
                    data-aos-duration="800"
                    data-aos-delay="200"
                >
                    nace desde la mirada de un equipo interdisciplinario de profesionales
                    dedicados a la <strong class="font-bold">comunicación, marketing, diseño y sostenibilidad.</strong>
                </p>

            </div>
        </div>
    </div>

</section>
