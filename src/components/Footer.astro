---
const phone     = import.meta.env.PUBLIC_WHATSAPP_PHONE;
const email     = import.meta.env.PUBLIC_EMAIL;
const linkedin  = import.meta.env.PUBLIC_LINKEDIN_URL;
const instagram = import.meta.env.PUBLIC_INSTAGRAM_URL;
const facebook  = import.meta.env.PUBLIC_FACEBOOK_URL;
const whatsapp  = `https://wa.me/${phone}`;
---

<footer id="reveal-footer" class="bg-degrade-3 py-20 fixed bottom-0 left-0 w-full -z-10 h-auto opacity-0 transition-opacity duration-300">
    <div class="container max-w-6xl mx-auto px-4 sm:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 items-center justify-center gap-14 sm:gap-8">

            <!-- Logo con slogan -->
            <section class="flex flex-row items-center justify-center md:justify-between">
                <div class="shrink-0">
                    <img
                        src="/images/logos/tresvecestres/logo-blanco-slogan.svg"
                        alt="Tres Veces Tres — Comunicación con impacto"
                        class="h-28 w-auto"
                        loading="lazy"
                    />
                </div>

                <!-- Separador vertical (solo desktop) -->
                <div class="hidden h-36 md:block self-stretch w-1 bg-white"></div>
            </section>

            <!-- Website Carbon badge (CSS) -->
            <section class="flex w-full flex-row items-center justify-center lg:justify-between">
                <ul class="text-white">
                    <li class="text-sm lg:text-base mt-1 text-center">
                        <span class="flex">
                            <span class="border-2 border-[#77bb5d] px-2 py-1">0.2g of CO₂ <em class="whitespace-nowrap">/ view</em></span>
                            <span class="bg-[#77bb5d] whitespace-nowrap  text-gris-cemento font-bold border-2 border-[#77bb5d] -ml-2 px-2 py-1">Website Carbon</span>
                        </span>
                        <p class="font-light text-center text-xs lg:text-sm mt-1">Cleaner than 96% of pages tested</p>
                    </li>
                </ul>

                <!-- Separador vertical (solo desktop) -->
                <div class="hidden h-36 lg:block self-stretch w-1 bg-white"></div>
            </section>
            <!-- Contacto + redes -->
            <section>
                <div class="flex flex-col items-center gap-4">
                    <!-- Email -->
                    <a
                        href={`mailto:${email}`}
                        class="group flex flex-row items-center gap-1 text-white hover:text-white/70 transition-colors duration-300"
                    >
                        <span class="font-bold text-lg">{email}</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-7 text-white/40 fill-white/40" viewBox="0 0 32 32">
                            <path fill="currentColor" d="M5 5v22h22V5zm2 2h18v18H7zm6 3v2h5.563L9.28 21.281l1.438 1.438L20 13.437V19h2v-9z" />
                        </svg>
                    </a>

                    <!-- Redes sociales -->
                    <div class="flex items-center gap-3">

                        <!-- LinkedIn -->
                        <a
                            href={linkedin}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="LinkedIn de Tres Veces Tres"
                            class="group size-10 rounded-full border-2 border-white bg-white flex items-center justify-center transition-colors duration-300 hover:bg-degrade-3"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-6 fill-degrade-3 transition-colors duration-300 group-hover:fill-white" aria-hidden="true">
                                <path d="M6.94 5a2 2 0 1 1-4-.002a2 2 0 0 1 4 .002M7 8.48H3V21h4zm6.32 0H9.34V21h3.94v-6.57c0-3.66 4.77-4 4.77 0V21H22v-7.93c0-6.17-7.06-5.94-8.72-2.91z" />
                            </svg>
                        </a>

                        <!-- Facebook -->
                        <!-- <a
                            href={facebook}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Facebook de Tres Veces Tres"
                            class="group size-10 rounded-full border-2 border-white bg-white flex items-center justify-center transition-colors duration-300 hover:bg-degrade-3"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-6 fill-degrade-3 transition-colors duration-300 group-hover:fill-white">
                                <path d="M14 13.5h2.5l1-4H14v-2c0-1.03 0-2 2-2h1.5V2.14c-.326-.043-1.557-.14-2.857-.14C11.928 2 10 3.657 10 6.7v2.8H7v4h3V22h4z" />
                            </svg>
                        </a> -->

                        <!-- Instagram -->
                        <a
                            href={instagram}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Instagram de Tres Veces Tres"
                            class="group size-10 rounded-full border-2 border-white bg-white flex items-center justify-center transition-colors duration-300 hover:bg-degrade-3"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-6 fill-degrade-3 transition-colors duration-300 group-hover:fill-white" aria-hidden="true">
                                <path d="M12.001 9a3 3 0 1 0 0 6a3 3 0 0 0 0-6m0-2a5 5 0 1 1 0 10a5 5 0 0 1 0-10m6.5-.25a1.25 1.25 0 0 1-2.5 0a1.25 1.25 0 0 1 2.5 0M12.001 4c-2.474 0-2.878.007-4.029.058c-.784.037-1.31.142-1.798.332a2.9 2.9 0 0 0-1.08.703a2.9 2.9 0 0 0-.704 1.08c-.19.49-.295 1.015-.331 1.798C4.007 9.075 4 9.461 4 12c0 2.475.007 2.878.058 4.029c.037.783.142 1.31.331 1.797c.17.435.37.748.702 1.08c.337.336.65.537 1.08.703c.494.191 1.02.297 1.8.333C9.075 19.994 9.461 20 12 20c2.475 0 2.878-.007 4.029-.058c.782-.037 1.308-.142 1.797-.331a2.9 2.9 0 0 0 1.08-.703c.337-.336.538-.649.704-1.08c.19-.492.296-1.018.332-1.8c.052-1.103.058-1.49.058-4.028c0-2.474-.007-2.878-.058-4.029c-.037-.782-.143-1.31-.332-1.798a2.9 2.9 0 0 0-.703-1.08a2.9 2.9 0 0 0-1.08-.704c-.49-.19-1.016-.295-1.798-.331C14.926 4.006 14.54 4 12 4m0-2c2.717 0 3.056.01 4.123.06c1.064.05 1.79.217 2.427.465c.66.254 1.216.598 1.772 1.153a4.9 4.9 0 0 1 1.153 1.772c.247.637.415 1.363.465 2.428c.047 1.066.06 1.405.06 4.122s-.01 3.056-.06 4.122s-.218 1.79-.465 2.428a4.9 4.9 0 0 1-1.153 1.772a4.9 4.9 0 0 1-1.772 1.153c-.637.247-1.363.415-2.427.465c-1.067.047-1.406.06-4.123.06s-3.056-.01-4.123-.06c-1.064-.05-1.789-.218-2.427-.465a4.9 4.9 0 0 1-1.772-1.153a4.9 4.9 0 0 1-1.153-1.772c-.248-.637-.415-1.363-.465-2.428C2.012 15.056 2 14.717 2 12s.01-3.056.06-4.122s.217-1.79.465-2.428a4.9 4.9 0 0 1 1.153-1.772A4.9 4.9 0 0 1 5.45 2.525c.637-.248 1.362-.415 2.427-.465C8.945 2.013 9.284 2 12.001 2" />
                            </svg>
                        </a>

                        <!-- WhatsApp -->
                        <a
                            href={whatsapp}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="WhatsApp de Tres Veces Tres"
                            class="group size-10 rounded-full border-2 border-white bg-white flex items-center justify-center transition-colors duration-300 hover:bg-degrade-3"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-6 fill-degrade-3 transition-colors duration-300 group-hover:fill-white" aria-hidden="true">
                                <path d="m7.254 18.494l.724.423A7.95 7.95 0 0 0 12.001 20a8 8 0 1 0-8-8a7.95 7.95 0 0 0 1.084 4.024l.422.724l-.653 2.401zM2.005 22l1.352-4.968A9.95 9.95 0 0 1 2.001 12c0-5.523 4.477-10 10-10s10 4.477 10 10s-4.477 10-10 10a9.95 9.95 0 0 1-5.03-1.355zM8.392 7.308q.202-.014.403-.004q.081.006.162.016c.159.018.334.115.393.249q.447 1.015.868 2.04c.062.152.025.347-.093.537c-.06.097-.154.233-.263.372c-.113.145-.356.411-.356.411s-.099.118-.061.265c.014.056.06.137.102.205l.059.095c.256.427.6.86 1.02 1.268c.12.116.237.235.363.346c.468.413.998.75 1.57 1l.005.002c.085.037.128.057.252.11q.093.039.191.066q.036.01.073.011a.35.35 0 0 0 .295-.142c.723-.876.79-.933.795-.933v.002a.48.48 0 0 1 .378-.127q.092.004.177.04c.531.243 1.4.622 1.4.622l.582.261c.098.047.187.158.19.265c.004.067.01.175-.013.373c-.032.259-.11.57-.188.733a1.2 1.2 0 0 1-.21.302a2.4 2.4 0 0 1-.33.288q-.124.092-.125.09a5 5 0 0 1-.383.22a2 2 0 0 1-.833.23c-.185.01-.37.024-.556.014c-.008 0-.568-.087-.568-.087a9.45 9.45 0 0 1-3.84-2.046c-.226-.199-.436-.413-.65-.626c-.888-.885-1.561-1.84-1.97-2.742a3.5 3.5 0 0 1-.33-1.413a2.73 2.73 0 0 1 .565-1.68c.073-.094.142-.192.261-.305c.126-.12.207-.184.294-.228a1 1 0 0 1 .371-.1" />
                            </svg>
                        </a>

                    </div>
                </div>
            </section>
        </div>
    </div>
</footer>
