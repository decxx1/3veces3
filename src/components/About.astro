---
---

<section class="relative overflow-hidden">

    <!-- PARTE BLANCA: cita -->
    <div class="relative bg-white">
        <div class="relative z-10 max-w-5xl mx-auto px-8 md:px-16 py-24 md:py-32">
            <!-- Comillas -->
            <svg class="w-10 h-10 mb-6 text-gray-300 fill-current" viewBox="0 0 32 24" aria-hidden="true">
                <path d="M0 24V14.4C0 6.48 4.56 1.44 13.68 0l1.44 2.88C10.32 4.08 7.92 6.96 7.2 10.8H13.2V24H0Zm18.8 0V14.4C18.8 6.48 23.36 1.44 32.48 0l1.44 2.88C29.12 4.08 26.72 6.96 26 10.8H32V24H18.8Z"/>
            </svg>

            <blockquote class="text-2xl md:text-3xl lg:text-4xl font-light italic text-gray-800 leading-snug max-w-xl">
                Todo lo positivo que hagas
                te será devuelto, multiplicado
                por tres&rdquo;.
            </blockquote>
        </div>

        <!-- Símbolo decorativo: sobresale hacia abajo -->
        <img
            src="/images/logos/simbolo-bg.svg"
            alt="símbolo de Tres Veces Tres decorativo"
            aria-hidden="true"
            class="absolute right-0 md:right-8 -top-10 h-[130%] w-auto pointer-events-none select-none"
        />
        <img
            src="/images/logos/simbolo-bg.svg"
            alt="símbolo de Tres Veces Tres decorativo en modo oscuro"
            aria-hidden="true"
            style="filter: brightness(0) invert(1) opacity(0.45);"
            class="absolute right-0 md:right-8 -top-10 h-[130%] w-auto pointer-events-none select-none"
        />
    </div>

    <!-- PARTE NEGRA: quiénes somos -->
    <div class="bg-[#0c0c0c]">
        <div class="max-w-5xl mx-auto px-8 md:px-16 py-24 md:py-32">
            <div class="flex flex-col md:flex-row items-start md:items-center gap-10 md:gap-16">

                <!-- Logo blanco letras (vertical) -->
                <div class="shrink-0">
                    <img
                        src="/images/logos/logo-blanco-letras.svg"
                        alt="Tres Veces Tres"
                        class="w-28 md:w-36"
                    />
                </div>

                <!-- Texto -->
                <p class="text-white text-lg md:text-xl leading-relaxed">
                    nace desde la mirada de un equipo interdisciplinario de profesionales
                    dedicados a la <strong class="font-bold">comunicación, marketing, diseño y sostenibilidad.</strong>
                </p>

            </div>
        </div>
    </div>

</section>
