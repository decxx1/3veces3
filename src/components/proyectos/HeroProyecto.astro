---
interface Props {
    bgImage: string;
    logo: string;
    alt: string;
    width?: string;
    transitionName?: string;
}

const { bgImage, logo, alt, width, transitionName = bgImage } = Astro.props;
---

<section class="relative flex h-160 sm:h-120 items-center overflow-hidden pt-32">
    <img
        src={bgImage}
        alt={'Portada de ' + alt}
        aria-hidden="true"
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover"
        transition:name={transitionName}
    />
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative z-10 mx-auto flex w-full max-w-5xl flex-col items-center gap-8 px-8 md:flex-row md:justify-between">
        <div
            class:list={[
                "flex shrink-0 items-center justify-center md:justify-start",
                width || "md:w-1/3"
            ]}
            data-aos="fade-right"
            data-aos-duration="800"
        >
            <img
                src={logo}
                alt={alt}
                loading="lazy"
                class="w-full max-w-xs drop-shadow-xl"
            />
        </div>
        <div
            class="text-center font-semibold md:text-left"
            data-aos="fade-left"
            data-aos-duration="800"
            data-aos-delay="200"
        >
            <slot />
        </div>
    </div>
</section>
