---
import ProyectoCard from './ProyectoCard.astro';
---

<section class="galeria-proyectos w-full flex flex-col gap-1.5 bg-white p-1.5">

  <!-- Row 1: redgroup — full width -->
  <div class="group relative overflow-hidden h-125 shrink-0">
    <ProyectoCard
      bg="/images/proyectos/bg-redgroup.webp"
      logo="/images/logos/empresas/redgroup.svg"
      alt="Redgroup"
      logoWidth="w-64"
    />
  </div>

  <!-- Row 2: btobcomex + pacha-magma — two columns -->
  <div class="duo-row flex gap-1.5 h-100 shrink-0">
    <div class="duo-card transition-[flex] duration-500 ease-in-out flex-1 min-w-0">
      <ProyectoCard
        bg="/images/proyectos/bg-btobcomex.webp"
        logo="/images/logos/empresas/btobcomex.svg"
        alt="BtoB Comex"
        logoWidth="w-72"
      />
    </div>
    <div class="duo-card transition-[flex] duration-500 ease-in-out flex-1 min-w-0">
      <ProyectoCard
        bg="/images/proyectos/bg-pacha-magma.webp"
        logo="/images/logos/empresas/pacha-magma.svg"
        alt="Pacha Magma"
        logoWidth="w-48"
      />
    </div>
  </div>

  <!-- Row 3: vodem — full width -->
  <div class="group relative overflow-hidden h-125 shrink-0">
    <ProyectoCard
      bg="/images/proyectos/bg-vodem.webp"
      logo="/images/logos/empresas/vodem.svg"
      alt="Vodem"
      logoWidth="w-52"
    />
  </div>

  <!-- Row 4: prosanitas + nexovitalis — two columns (gradient backgrounds) -->
  <div class="duo-row flex gap-1.5 h-100 shrink-0">
    <div class="duo-card transition-[flex] duration-500 ease-in-out flex-1 min-w-0">
      <ProyectoCard
        gradientClass="bg-linear-to-br from-gray-400 to-gray-500"
        logo="/images/logos/empresas/prosanitas.png"
        alt="Prosanitas"
        logoWidth="w-52"
      />
    </div>
    <div class="duo-card transition-[flex] duration-500 ease-in-out flex-1 min-w-0">
      <ProyectoCard
        gradientClass="bg-linear-to-br from-blue-900 to-blue-950"
        logo="/images/logos/empresas/nexovitalis.png"
        alt="Nexovitalis"
        logoWidth="w-58"
      />
    </div>
  </div>

  <!-- Row 5: atxona — full width -->
  <div class="group relative overflow-hidden h-125 shrink-0">
    <ProyectoCard
      bg="/images/proyectos/bg-atxona.webp"
      logo="/images/logos/empresas/atxona.svg"
      alt="Grupo Atxona"
      logoWidth="w-80"
    />
  </div>

</section>

<style>
  /* Two-column expand/shrink on hover using :has() */
  .duo-row:has(.duo-card:first-child:hover) .duo-card:first-child { flex: 1.6; }
  .duo-row:has(.duo-card:first-child:hover) .duo-card:last-child  { flex: 0.4; }
  .duo-row:has(.duo-card:last-child:hover)  .duo-card:last-child  { flex: 1.6; }
  .duo-row:has(.duo-card:last-child:hover)  .duo-card:first-child { flex: 0.4; }
</style>
