---
---

<!-- Título sobre fondo blanco -->
<section
    class="pb-24 px-8 text-center"
    data-aos="fade-down"
    data-aos-duration="800"
>
    <h2 class="text-4xl lg:text-5xl max-w-xl mx-auto font-light">Soporte y diseño de comunicación interna</h2>
</section>

<!-- Franja oscura — la imagen sobresale por arriba -->
<section class="relative overflow-visible">
    <!-- Fondo oscuro que NO cubre la parte superior donde sobresale la imagen -->
    <div class="absolute inset-x-0 bottom-0 top-32 md:top-56 bg-[#22232d]"></div>

    <!-- Símbolo decorativo - grande, abajo izquierda, parcialmente recortado -->
    <img
        src="/images/proyectos/redgroup/hey-reds-symbol.svg"
        alt="Símbolo decorativo de Red Group - Hey Reds"
        aria-hidden="true"
        loading="lazy"
        class="absolute -bottom-16 -left-16 w-80 md:w-120 lg:w-150 pointer-events-none"
        data-aos="fade-left"
        data-aos-duration="1000"
        data-aos-delay="300"
    />

    <!-- Contenido -->
    <div class="relative z-10 container mx-auto px-8 pb-24 md:pb-32 flex flex-col md:flex-row items-end md:items-end gap-8 md:gap-16">
        <!-- SVG "¡Hey reds!" - alineado abajo a la izquierda -->
        <div
            class="order-2 md:order-1 flex-1 flex items-end justify-center pt-8 md:pt-32"
            data-aos="fade-right"
            data-aos-duration="800"
            data-aos-delay="150"
        >
            <img
                src="/images/proyectos/redgroup/hey-reds-text.svg"
                alt="¡Hey reds!"
                loading="lazy"
                class="w-56 md:w-72 xl:w-96 drop-shadow-xl"
            />
        </div>

        <!-- Imagen que sobresale por arriba del fondo oscuro -->
        <div
            class="order-1 md:order-2 flex-1 flex justify-center md:justify-center"
            data-aos="fade-up"
            data-aos-duration="800"
            data-aos-delay="300"
        >
            <img
                src="/images/proyectos/redgroup/hey-reds-image.png"
                alt="Hey Reds - comunicación interna Redgroup"
                loading="lazy"
                class="w-full max-w-xs md:max-w-sm xl:max-w-md rounded-lg drop-shadow-2xl"
            />
        </div>
    </div>
</section>
