---
---

<section class="relative overflow-hidden">

    <!-- PARTE BLANCA: cita -->
    <div class="relative bg-white">
        <div class="relative z-10 max-w-5xl mx-auto px-8 md:px-16 py-24 md:py-32">
            <!-- Comillas -->
            <svg class="size-20 mb-6 text-gray-300 fill-current rotate-180" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <g fill="none">
                    <path fill-opacity="0.16" d="M10.99 9.449c.178 3.09-1.998 7.444-6.88 9.551L3 17.08c1.997-1.123 3.507-2.95 4.306-5.15c-2.886-.234-3.729-2.013-3.729-3.464c0-1.967 1.51-3.512 3.374-3.465c1.775-.047 3.817 1.311 4.039 4.448m10 0c.178 3.09-1.997 7.444-6.88 9.551L13 17.08c1.998-1.123 3.507-2.95 4.306-5.15c-2.886-.234-3.729-2.013-3.729-3.464c0-1.967 1.51-3.512 3.374-3.465c1.775-.047 3.817 1.311 4.039 4.448" />
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-miterlimit="10" stroke-width="1.5" d="M10.99 9.449c.178 3.09-1.998 7.444-6.88 9.551L3 17.08c1.997-1.123 3.507-2.95 4.306-5.15c-2.886-.234-3.729-2.013-3.729-3.464c0-1.967 1.51-3.512 3.374-3.465c1.775-.047 3.817 1.311 4.039 4.448m10 0c.178 3.09-1.997 7.444-6.88 9.551L13 17.08c1.998-1.123 3.507-2.95 4.306-5.15c-2.886-.234-3.729-2.013-3.729-3.464c0-1.967 1.51-3.512 3.374-3.465c1.775-.047 3.817 1.311 4.039 4.448" />
                </g>
            </svg>

            <blockquote class="text-2xl md:text-3xl lg:text-4xl xl:text-5xl max-w-xl lg:max-w-176 font-light italic text-gray-800 leading-snug">
                Todo lo positivo que hagas te será devuelto, multiplicado por tres&rdquo;.
            </blockquote>
        </div>

        <!-- Símbolo decorativo: sobresale hacia abajo -->
        <img
            src="/images/logos/simbolo-bg.svg"
            alt="símbolo de Tres Veces Tres decorativo"
            aria-hidden="true"
            class="absolute right-0 md:right-8 xl:right-64 -top-10 h-[125%] w-auto pointer-events-none select-none"
        />
        <img
            src="/images/logos/simbolo-bg.svg"
            alt="símbolo de Tres Veces Tres decorativo en modo oscuro"
            aria-hidden="true"
            style="filter: brightness(0) invert(1) opacity(0.45);"
            class="absolute right-0 md:right-8 xl:right-64 -top-10 h-[125%] w-auto pointer-events-none select-none"
        />
    </div>

    <!-- PARTE NEGRA: quiénes somos -->
    <div class="bg-[#0c0c0c]">
        <div class="max-w-5xl mx-auto px-8 md:px-16 py-24 md:py-32 lg:py-36">
            <div class="flex flex-col md:flex-row items-start md:items-center gap-10 md:gap-16">

                <!-- Logo blanco letras (vertical) -->
                <div class="shrink-0">
                    <img
                        src="/images/logos/logo-blanco-letras.svg"
                        alt="Tres Veces Tres"
                        class="w-28 md:w-36 lg:w-44"
                    />
                </div>

                <!-- Texto -->
                <p class="text-white text-lg md:text-xl lg:text-2xl leading-relaxed">
                    nace desde la mirada de un equipo interdisciplinario de profesionales
                    dedicados a la <strong class="font-bold">comunicación, marketing, diseño y sostenibilidad.</strong>
                </p>

            </div>
        </div>
    </div>

</section>
