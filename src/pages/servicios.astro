---
import Layout from '@/layouts/Layout.astro';
import HeroGradient from '@/components/HeroGradient.astro';
import ServiciosGrid from '@/components/servicios/ServiciosGrid.astro';
import CtaWhatsapp from '@/components/index/CtaWhatsapp.astro';
---

<Layout
    title="Servicios | Tres Veces Tres"
    canonical="https://tresvecestres.com.ar/servicios"
    metaDescription="Conocé los servicios de comunicación y marketing de Tres Veces Tres."
    metaImg=""
>
    <HeroGradient>
        <span class="flex flex-col items-center w-fit mx-auto">
            <span class="italic font-light">Trabajamos para</span>
            <strong class="font-semibold sm:font-bold">multiplicar</strong>
            <span class="flex flex-col sm:flex-row items-center gap-3 md:gap-4">
                <strong class="font-semibold sm:font-bold">el impacto</strong>
                <span class="text-white sm:max-w-32 text-base md:text-xl font-medium leading-tight text-left block">
                    de cada proyecto.
                </span>
            </span>
        </span>
    </HeroGradient>
    <ServiciosGrid />
    <CtaWhatsapp />
</Layout>
