---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/index/Hero.astro';
import About from '@/components/index/About.astro';
import Team from '@/components/index/Team.astro';
import CtaWhatsapp from '@/components/index/CtaWhatsapp.astro';
const preloadImages = [
	{
		href: "",
		as: "image",
		type: "image/webp",
	},
];
---

<Layout
	title="Tres Veces Tres"
	canonical="https://tresvecestres.com.ar"
	metaDescription="Somos una agencia de comunicación y marketing, combinamos estrategia, creatividad y conciencia para impulsar el Impacto Positivo en marcas, organizaciones y proyectos"
	metaImg="/images/logo-fondo.webp"
	preLoad={preloadImages}
>
	<Hero />
	<About />
	<Team />
	<CtaWhatsapp />
</Layout>
