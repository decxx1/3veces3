---

<section class="relative py-24">
    <!-- símbolo decorativo de fondo -->
    <img
        src="/images/proyectos/redgroup/simbolo-linear.svg"
        alt=""
        aria-hidden="true"
        class="absolute -bottom-20 sm:-bottom-56 lg:-bottom-80 -right-24 md:-right-16 w-64 sm:w-96 lg:w-150 xl:w-180 pointer-events-none "
    />

    <div class="container mx-auto px-8 z-10 relative">
        <h2 class="text-4xl lg:text-5xl max-w-xl mx-auto font-light text-center mb-22">Estrategia y gestión de comunicación digital</h2>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <img
                src="/images/proyectos/redgroup/flyer-1.webp"
                alt="Viernes Redcomendado"
                class="w-full h-full md:w-auto sm:h-auto md:max-h-130 xl:max-h-190 rounded-sm"
            />
            <img
                src="/images/proyectos/redgroup/flyer-2.webp"
                alt="FocalMode 2026 - Javiera Infante Projects"
                class="w-full h-full md:w-auto sm:h-auto md:max-h-130 xl:max-h-190 rounded-sm"
            />
            <img
                src="/images/proyectos/redgroup/flyer-3.webp"
                alt="22 fotógrafos, 22 series inéditas"
                class="w-full h-full md:w-auto sm:h-auto md:max-h-130 xl:max-h-190 rounded-sm"
            />
        </div>
        
    </div>
</section>
<section class="mt-4 sm:mt-24 pb-24 flex justify-center">
    <img
        src="/images/proyectos/redgroup/mockup-redes.webp"
        alt="22 fotógrafos, 22 series inéditas"
        class="w-full h-full md:w-auto sm:h-auto md:max-h-130 xl:max-h-190 rounded-sm"
    />
</section>
