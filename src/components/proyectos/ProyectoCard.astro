---
interface Props {
  bg?: string;         // ruta a la imagen de fondo (opcional)
  gradientClass?: string; // clases de gradiente tailwind si no hay imagen
  logo: string;        // ruta al logo
  alt: string;         // alt del logo
  logoWidth?: string;  // clase de ancho del logo, ej: "w-52"
}

const { bg, gradientClass = '', logo, alt, logoWidth = 'w-52' } = Astro.props;
---

<div class:list={['proyecto-card group relative overflow-hidden w-full h-full cursor-pointer', gradientClass]}>
  {bg && (
    <img
      src={bg}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105"
    />
  )}
  <div class="absolute inset-0 bg-black/40 transition-colors duration-500 group-hover:bg-black/25"></div>
  <div class="absolute inset-0 flex items-center justify-center">
    <img
      src={logo}
      alt={alt}
      class:list={[logoWidth, 'max-w-[55%] brightness-0 invert drop-shadow-lg transition-transform duration-500 group-hover:scale-110']}
    />
  </div>
</div>
